<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:animationCache="true"
    android:background="#000000"
    android:backgroundTint="#000000"
    tools:context=".vista.inicio_sesion">

    <Button
        android:id="@+id/btnIniciarSesion"
        android:layout_width="201dp"
        android:layout_height="68dp"
        android:text="JUGAR"
        android:textSize="34sp"
        tools:layout_editor_absoluteX="109dp"
        tools:layout_editor_absoluteY="525dp" />

    <EditText
        android:id="@+id/editUsuario"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text"
        android:text="USUARIO"
        android:textColor="#FFEBEE"
        android:textColorHighlight="#FFEBEE"
        android:textColorHint="#FFEBEE"
        android:textColorLink="#FFEBEE"
        tools:layout_editor_absoluteX="100dp"
        tools:layout_editor_absoluteY="369dp" />

    <EditText
        android:id="@+id/editContrasena"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text"
        android:text="CONTRASEÑA"
        android:textColor="#FFEBEE"
        android:textColorHighlight="#FFEBEE"
        android:textColorHint="#FFEBEE"
        android:textColorLink="#FFEBEE"
        tools:layout_editor_absoluteX="100dp"
        tools:layout_editor_absoluteY="442dp" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿NO TIENES CUENTA? REGÍSTRATE AQUÍ"
        android:textColor="#FFEBEE"
        android:textColorHighlight="#FFEBEE"
        android:textColorHint="#FFEBEE"
        android:textColorLink="#FFEBEE"
        android:textSize="16sp"
        android:visibility="visible"
        tools:layout_editor_absoluteX="59dp"
        tools:layout_editor_absoluteY="641dp"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="257dp"
        android:layout_height="152dp"
        android:text="LETRIX"
        android:textAlignment="center"
        android:textSize="60sp"
        android:textStyle="bold"
        android:visibility="visible"
        tools:layout_editor_absoluteX="67dp"
        tools:layout_editor_absoluteY="38dp"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/imageView11"
        android:layout_width="423dp"
        android:layout_height="479dp"
        app:srcCompat="@drawable/logoletrix"
        tools:layout_editor_absoluteX="-6dp"
        tools:layout_editor_absoluteY="0dp" />

</androidx.constraintlayout.widget.ConstraintLayout>